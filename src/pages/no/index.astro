---
import { getEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Resume from "../../components/Resume.astro";
import { locales } from "../../i18n";

const locale = locales.no;
const entry = await getEntry("resume", locale.entryId);
if (!entry)
  throw new Error(
    "resume JSON missing — run `mise //content:build` to generate it",
  );
const description = `${entry.data.name} — ${entry.data.tagline}`;
---

<Layout
  lang={locale.lang}
  title={locale.t.title}
  description={description}
  path={locale.path}
>
  <Resume locale={locale} data={entry.data} />
</Layout>
