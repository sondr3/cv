---
import type { Locale } from "../i18n";
import Icon from "./Icon.astro";

interface Props {
  t: Locale["t"];
}

const { t } = Astro.props;

const options = [
  { value: "light", icon: "sun", label: t.themeLight },
  { value: "dark", icon: "moon", label: t.themeDark },
  { value: "system", icon: "monitor", label: t.themeSystem },
] as const;
---

<div
  role="group"
  aria-label={t.theme}
  class="flex items-center rounded border border-zinc-300 dark:border-zinc-700"
>
  {
    options.map((option) => (
      <button
        type="button"
        data-theme-value={option.value}
        aria-label={option.label}
        title={option.label}
        class="px-1.5 py-1 text-zinc-400 hover:text-zinc-600 aria-pressed:text-accent dark:text-zinc-600 dark:hover:text-zinc-400 dark:aria-pressed:text-accent-soft"
      >
        <Icon name={option.icon} class="size-3.5" />
      </button>
    ))
  }
</div>

<script>
  const media = window.matchMedia("(prefers-color-scheme: dark)");
  const buttons = document.querySelectorAll<HTMLButtonElement>(
    "button[data-theme-value]",
  );

  const stored = () => {
    try {
      return localStorage.getItem("theme") ?? "system";
    } catch {
      return "system";
    }
  };

  const apply = () => {
    const theme = stored();
    const dark = theme === "dark" || (theme === "system" && media.matches);
    document.documentElement.dataset.theme = dark ? "dark" : "light";
    for (const button of buttons) {
      button.setAttribute(
        "aria-pressed",
        String(button.dataset.themeValue === theme),
      );
    }
  };

  for (const button of buttons) {
    button.addEventListener("click", () => {
      try {
        localStorage.setItem("theme", button.dataset.themeValue ?? "system");
      } catch {
        /* theme just won't persist */
      }
      apply();
    });
  }

  media.addEventListener("change", apply);
  apply();
</script>
