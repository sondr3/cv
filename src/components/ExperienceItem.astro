---
import type { CollectionEntry } from "astro:content";
import Tag from "./Tag.astro";

interface Props {
  job: CollectionEntry<"resume">["data"]["experience"][number];
  present: string;
}

const { job, present } = Astro.props;
---

<article>
  <div
    class="flex flex-col gap-x-4 sm:flex-row sm:items-baseline sm:justify-between"
  >
    <h3 class="font-medium">{job.position}</h3>
    <p class="shrink-0 font-mono text-sm text-zinc-500 dark:text-zinc-300">
      {job.start}–{job.end ?? present}
    </p>
  </div>
  <div
    class="flex flex-col gap-x-4 sm:flex-row sm:items-baseline sm:justify-between"
  >
    <p class="text-zinc-600 italic dark:text-zinc-300">{job.company}</p>
    <p class="shrink-0 text-sm text-zinc-500 dark:text-zinc-300">
      {job.location}
    </p>
  </div>
  <ul
    class="mt-2 list-disc space-y-1.5 pl-5 marker:text-accent/50 dark:marker:text-accent-soft/50"
  >
    {job.about.map((line) => <li>{line}</li>)}
  </ul>
  <div class="mt-3 flex flex-wrap gap-1.5">
    {job.technologies.map((tech) => <Tag label={tech} />)}
  </div>
</article>
